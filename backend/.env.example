# ═══════════════════════════════════════════════════════════════════════════════
# PETALS & FLORA - ENVIRONMENT CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your environment
# NEVER commit .env to version control - it contains sensitive data
# ═══════════════════════════════════════════════════════════════════════════════

# ─── DJANGO SECURITY SETTINGS ───────────────────────────────────────────────────
# EXTREMELY IMPORTANT: Generate a strong secret key for production
# Run: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace_me_with_a_long_random_secret

# Set to False in production - CRITICAL for security
DJANGO_DEBUG=False

# ─── ALLOWED HOSTS (CORS & CSRF) ────────────────────────────────────────────────
# Comma-separated list of allowed domains (prevents Host header injection)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver

# Frontend URLs allowed to make API requests (CORS)
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Origins allowed for CSRF validation
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── DATABASE CONFIGURATION ────────────────────────────────────────────────────
# MongoDB connection string - use strong authentication
MONGO_URI=mongodb://127.0.0.1:27017/

# MongoDB database name
MONGO_DB_NAME=petals_flora_db

# ─── PAYMENT GATEWAY (RAZORPAY) ────────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com/app/keys
# Use TEST keys in development, LIVE keys in production
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_test_key_secret

# ─── RATE LIMITING ──────────────────────────────────────────────────────────────
# Format: number/period (e.g., "60/minute", "1000/hour")
# Prevent brute force and DoS attacks
DRF_THROTTLE_ANON=60/minute
DRF_THROTTLE_USER=120/minute
DRF_THROTTLE_PRODUCTS=120/minute
DRF_THROTTLE_ORDERS=30/minute
DRF_THROTTLE_PAYMENTS=10/minute

# ─── SESSION SECURITY ──────────────────────────────────────────────────────────
# Session timeout in seconds (default: development 28800 = 8 hours, production: 7200 = 2 hours)
DJANGO_SESSION_COOKIE_AGE=28800

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY BEST PRACTICES
# ═══════════════════════════════════════════════════════════════════════════════
# 
# 1. SECRET KEY:
#    - Generate a new strong key: python -c "import secrets; print(secrets.token_urlsafe(50))"
#    - Keep it secret and separate for each environment
#    - Rotate periodically
#
# 2. DEBUG MODE:
#    - ALWAYS set DJANGO_DEBUG=False in production
#    - Debug mode exposes sensitive information
#
# 3. ALLOWED HOSTS:
#    - Only include your actual domain(s)
#    - Prevents Host header injection attacks
#
# 4. CORS/CSRF:
#    - Only allow origins that need to access your API
#    - Be specific - never use wildcards (*) in production
#    - Update CORS_ALLOWED_ORIGINS for production domains
#    - Update CSRF_TRUSTED_ORIGINS when deploying
#
# 5. MONGODB:
#    - Use strong authentication credentials
#    - Enable network access restrictions
#    - Enable database encryption at rest
#    - Use SSL/TLS for connections: mongodb+srv://...
#
# 6. API KEYS (Razorpay):
#    - Never commit real keys to version control
#    - Use TEST keys in development
#    - Rotate LIVE keys periodically
#    - Monitor for unauthorized usage
#
# 7. RATE LIMITING:
#    - Adjust rates based on expected traffic
#    - Stricter limits for payment endpoints
#    - Monitor for abuse patterns
#    - Consider IP-based rate limiting for production
#
# ═══════════════════════════════════════════════════════════════════════════════
