DJANGO_SECRET_KEY=replace_with_strong_secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-backend-domain.vercel.app
DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.vercel.app
DATABASE_URL=postgresql://username:password@hostname:5432/database_name?sslmode=require
MONGO_URI=mongodb://127.0.0.1:27017/
MONGO_DB_NAME=petals_flora_db
RAZORPAY_KEY_ID=rzp_test_public_key
RAZORPAY_KEY_SECRET=razorpay_secret_key
RAZORPAY_WEBHOOK_SECRET=razorpay_webhook_secret
FRONTEND_BASE_URL=https://your-frontend-domain.vercel.app
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=youraddress@gmail.com
DJANGO_EMAIL_HOST_PASSWORD=your_app_password
DJANGO_EMAIL_USE_TLS=True
DJANGO_DEFAULT_FROM_EMAIL=Petals & Flora <no-reply@petalsandfloras.com>
DRF_THROTTLE_ANON=60/minute
DRF_THROTTLE_USER=120/minute
DRF_THROTTLE_PAYMENTS=10/minute
DRF_THROTTLE_ORDERS=30/minute
